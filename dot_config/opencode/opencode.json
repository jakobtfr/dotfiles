{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/code/dotfiles/agent-coding/AGENTS.md"
  ],
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "provider": {
    "azure": {
      "name": "Azure OpenAI",
      "options": {
        "baseURL": "https://oai-coding-4890.openai.azure.com/openai"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5 Azure",
          "family": "openai",
          "release_date": "2026-04-24",
          "attachment": true,
          "reasoning": true,
          "temperature": false,
          "tool_call": true,
          "limit": {
            "context": 90000,
            "output": 10000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "model": "azure/gpt-5.5",
  "small_model": "azure/gpt-5.5"
}
