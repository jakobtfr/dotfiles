{{- if .email }}
display-name = "Jakob Friedrich"
signature = ""

[accounts.gmail]
default = true
email = "{{ .email }}"

folder.alias.inbox = "INBOX"
folder.alias.sent = "[Gmail]/Sent Mail"
folder.alias.drafts = "[Gmail]/Drafts"
folder.alias.trash = "[Gmail]/Trash"

backend.type = "imap"
backend.host = "imap.gmail.com"
backend.port = 993
backend.encryption = "tls"
backend.login = "{{ .email }}"
backend.auth.type = "password"
backend.auth.command = "security find-generic-password -s himalaya-gmail -a {{ .email }} -w"

message.send.backend.type = "smtp"
message.send.backend.host = "smtp.gmail.com"
message.send.backend.port = 465
message.send.backend.encryption = "tls"
message.send.backend.login = "{{ .email }}"
message.send.backend.auth.type = "password"
message.send.backend.auth.command = "security find-generic-password -s himalaya-gmail -a {{ .email }} -w"
{{- end }}
